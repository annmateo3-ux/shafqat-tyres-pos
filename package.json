{
  "name": "shafqat-tyres",
  "version": "1.0.5",
  "description": "Shafqat Tyres & Rim House - POS & Inventory Management",
  "main": "src/main/main.js",
  "scripts": {
    "vite": "vite",
    "dev": "concurrently \"npm run vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder --win",
    "dist": "vite build && electron-builder --win --publish always"
  },
  "keywords": [],
  "author": "Shafqat Tyres",
  "license": "ISC",
  "dependencies": {
    "sql.js": "^1.12.0",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.3.9",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.shafqattyres.pos",
    "productName": "Shafqat Tyres POS",
    "publish": {
      "provider": "github",
      "owner": "annmateo3-ux",
      "repo": "shafqat-tyres-pos",
      "private": true
    },
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "release"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "node_modules/**/*",
      "!node_modules/electron-builder/**/*"
    ]
  }
}
